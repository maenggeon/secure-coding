# Copy this file to .env and replace every value before deployment.
POSTGRES_DB=marketplace
POSTGRES_USER=marketplace
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Generate strong, distinct values (for example: openssl rand -hex 32).
SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-another-long-random-secret

ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisAdminPassword!123
ADMIN_EMAIL=admin@example.com

# The site will be available at http://localhost:8080
FRONTEND_PORT=8080
